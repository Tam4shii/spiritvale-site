# Copy to .env and fill in your bot token.
# Never commit .env — it's in .gitignore.

# Required: Discord bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_token_here

# Optional: channel ID for new-patch auto-announcements (right-click channel → Copy ID).
# Leave blank to run command-only mode; !patch / !diff / !versions still work without it.
SPIRITVALE_CHANNEL_ID=
