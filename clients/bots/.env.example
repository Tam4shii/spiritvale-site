# Copy to .env and fill in your bot token.
# Never commit .env — it's in .gitignore.

# Required: Discord bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_token_here

# Optional: channel ID for new-patch auto-announcements (right-click channel → Copy ID).
# Leave blank to run command-only mode; slash commands and !patch / !diff still work without it.
SPIRITVALE_CHANNEL_ID=

# Note: when generating the bot invite URL, include BOTH scopes:
#   bot + applications.commands
# The applications.commands scope is required for slash commands (/latest, /diff, /search).
# Without it the bot joins the server but slash commands never appear.
